@model WorkoutSessionEditModel
@{
    ViewData["Title"] = "New Session";
    var programs = (IReadOnlyList<WorkoutProgramDto>)ViewData["Programs"]!;
    var programSplits = (Dictionary<Guid, IReadOnlyList<WorkoutProgramSplitDto>>)(ViewData["ProgramSplits"] ?? new Dictionary<Guid, IReadOnlyList<WorkoutProgramSplitDto>>());

    var programSplitsJson = programSplits.ToDictionary(
        kv => kv.Key.ToString(),
        kv => kv.Value
            .Where(s => !s.IsDeleted)
            .OrderBy(s => s.Order)
            .Select(s => new { id = s.Id, name = $"{s.Order}. {s.Name}" })
            .ToArray());
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">New Workout Session</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to list
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="WorkoutProgramId" class="form-label">Program</label>
                <select asp-for="WorkoutProgramId" id="program-select" class="form-select">
                    <option value="">-- select program --</option>
                    @foreach (var p in programs)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
                <span asp-validation-for="WorkoutProgramId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="WorkoutProgramSplitId" class="form-label">Split</label>
                <select asp-for="WorkoutProgramSplitId" id="split-select" class="form-select" disabled>
                    <option value="">-- select program first --</option>
                </select>
                <span asp-validation-for="WorkoutProgramSplitId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Date" class="form-label"></label>
                <input asp-for="Date" class="form-control" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Create
                </button>
                <a asp-action="Index" class="btn btn-ghost-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const programSplits = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(programSplitsJson));
            const programSelect = document.getElementById('program-select');
            const splitSelect = document.getElementById('split-select');
            if (!programSelect || !splitSelect) return;

            function refreshSplits() {
                const programId = programSelect.value;
                splitSelect.innerHTML = '';
                const splits = programId ? (programSplits[programId] || []) : [];
                if (!programId) {
                    const opt = document.createElement('option');
                    opt.value = '';
                    opt.textContent = '-- select program first --';
                    splitSelect.appendChild(opt);
                    splitSelect.disabled = true;
                    return;
                }
                if (splits.length === 0) {
                    const opt = document.createElement('option');
                    opt.value = '';
                    opt.textContent = '-- no splits in this program --';
                    splitSelect.appendChild(opt);
                    splitSelect.disabled = true;
                    return;
                }
                const placeholder = document.createElement('option');
                placeholder.value = '';
                placeholder.textContent = '-- select split --';
                splitSelect.appendChild(placeholder);
                splits.forEach(function (s) {
                    const opt = document.createElement('option');
                    opt.value = s.id;
                    opt.textContent = s.name;
                    splitSelect.appendChild(opt);
                });
                splitSelect.disabled = false;
            }

            programSelect.addEventListener('change', refreshSplits);
            refreshSplits();
        })();
    </script>
}
