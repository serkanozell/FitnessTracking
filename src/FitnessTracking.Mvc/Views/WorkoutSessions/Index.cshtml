@model PagedResult<WorkoutSessionDto>
@{
    ViewData["Title"] = "Workout Sessions";
    var programs = (IReadOnlyList<WorkoutProgramDto>)ViewData["Programs"]!;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Workout Sessions</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Session
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Program</th>
                        <th>Date</th>
                        <th class="text-end" style="width: 180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-center text-body-secondary py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>No sessions found.
                            </td>
                        </tr>
                    }
                    @foreach (var s in Model.Items)
                    {
                        var programName = programs.FirstOrDefault(p => p.Id == s.WorkoutProgramId)?.Name
                                         ?? s.WorkoutProgramId.ToString()[..8];
                        <tr>
                            <td class="fw-semibold">@programName</td>
                            <td>@s.Date.ToShortDateString()</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye me-1"></i>Details
                                </a>
                                <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this session?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_PaginationPartial", new PaginationViewModel
{
    PageNumber = Model.PageNumber,
    PageSize = Model.PageSize,
    TotalCount = Model.TotalCount,
    TotalPages = Model.TotalPages,
    HasNextPage = Model.HasNextPage,
    HasPreviousPage = Model.HasPreviousPage
})
