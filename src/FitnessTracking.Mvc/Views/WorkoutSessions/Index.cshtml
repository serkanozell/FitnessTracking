@model PagedResult<WorkoutSessionDto>
@{
    ViewData["Title"] = "Workout Sessions";
    var programs = (IReadOnlyList<WorkoutProgramDto>)ViewData["Programs"]!;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="mb-0">Workout Sessions</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Session
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-light">
                <tr>
                    <th>Program</th>
                    <th>Date</th>
                    <th style="width: 180px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">No sessions found.</td></tr>
                }
                @foreach (var s in Model.Items)
                {
                    var programName = programs.FirstOrDefault(p => p.Id == s.WorkoutProgramId)?.Name
                                     ?? s.WorkoutProgramId.ToString()[..8];
                    <tr>
                        <td>@programName</td>
                        <td>@s.Date.ToShortDateString()</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this session?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
