@model PagedResult<WorkoutSessionDto>
@{
    ViewData["Title"] = "Workout Sessions";
    var programs = (IReadOnlyList<WorkoutProgramDto>)ViewData["Programs"]!;
    var allExercises = (IReadOnlyList<ExerciseDto>)ViewData["AllExercises"]!;
    // Pre-build O(1) lookups so per-row rendering doesn't degrade to O(N*M).
    var programsById = programs.ToDictionary(p => p.Id);
    var exercisesById = allExercises.ToDictionary(e => e.Id);
    var expandSessionId = Context.Request.Query["expand"].FirstOrDefault();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Workout Sessions</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Session
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Program</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="text-end" style="width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-center text-body-secondary py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>No sessions found.
                            </td>
                        </tr>
                    }
                    @foreach (var session in Model.Items)
                    {
                        var programName = programsById.TryGetValue(session.WorkoutProgramId, out var prog)
                            ? prog.Name
                            : session.WorkoutProgramId.ToString()[..8];
                        var exercises = session.Exercises;
                        var expandId = $"expand-{session.Id}";
                        var shouldExpand = session.Id.ToString() == expandSessionId;

                        <tr>
                            <td class="fw-semibold">
                                <button class="btn btn-sm p-0 me-2 expand-toggle @(shouldExpand ? "" : "collapsed")"
                                        type="button"
                                        data-coreui-toggle="collapse" data-coreui-target="#@expandId">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                                @programName
                                @if (exercises.Count > 0)
                                {
                                    <span class="badge bg-primary-subtle text-primary ms-2">@exercises.Count sets</span>
                                }
                            </td>
                            <td>@session.Date.ToShortDateString()</td>
                            <td>
                                @if (session.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@session.Id" class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (!session.IsActive)
                                {
                                    <form asp-action="Activate" asp-route-id="@session.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Activate">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>
                                }
                                <form asp-action="Delete" asp-route-id="@session.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this session?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <!-- Expandable exercise detail row -->
                        <tr>
                            <td colspan="4" class="p-0 border-0">
                                <div class="collapse @(shouldExpand ? "show" : "")" id="@expandId">
                                    <div class="px-4 py-3 bg-body-tertiary border-top">

                                        <!-- Add Set -->
                                        @{
                                            var nextSetByExercise = exercises
                                                .GroupBy(x => x.ExerciseId)
                                                .ToDictionary(g => g.Key, g => g.Max(s => s.SetNumber) + 1);
                                            var addSelectId = $"addSetExerciseSelect-{session.Id}";
                                            var addSetInputId = $"addSetNumber-{session.Id}";
                                        }
                                        <form asp-action="AddExercise" asp-route-id="@session.Id" method="post" class="mb-3">
                                            <input type="hidden" name="returnTo" value="Index" />
                                            <input type="hidden" name="page" value="@Model.PageNumber" />
                                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                            <div class="row g-2 align-items-end">
                                                <div class="col-md-3">
                                                    <label class="form-label small fw-semibold">Exercise</label>
                                                    <select name="exerciseId" id="@addSelectId"
                                                            class="form-select form-select-sm add-set-exercise"
                                                            data-set-input="#@addSetInputId" required>
                                                        <option value="">-- select --</option>
                                                        @foreach (var ex in allExercises)
                                                        {
                                                            var nextSet = nextSetByExercise.GetValueOrDefault(ex.Id, 1);
                                                            <option value="@ex.Id" data-next-set="@nextSet">@ex.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label small fw-semibold">Set #</label>
                                                    <input name="setNumber" id="@addSetInputId" type="number" class="form-control form-control-sm" value="1" min="1" />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label small fw-semibold">Weight</label>
                                                    <input name="weight" type="number" step="0.5" class="form-control form-control-sm" value="0" />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label small fw-semibold">Reps</label>
                                                    <input name="reps" type="number" class="form-control form-control-sm" value="10" min="1" />
                                                </div>
                                                <div class="col-md-3">
                                                    <button type="submit" class="btn btn-success btn-sm w-100">
                                                        <i class="bi bi-plus-lg me-1"></i>Add Set
                                                    </button>
                                                </div>
                                            </div>
                                        </form>

                                        @if (exercises.Count == 0)
                                        {
                                            <p class="text-body-secondary mb-0 text-center py-2">
                                                <i class="bi bi-inbox me-1"></i>No exercises recorded. Add one above.
                                            </p>
                                        }
                                        else
                                        {
                                            var groupedExercises = exercises
                                                .GroupBy(x => x.ExerciseId)
                                                .Select(g => new
                                                {
                                                    ExerciseId = g.Key,
                                                    Name = exercisesById.TryGetValue(g.Key, out var ex) ? ex.Name : g.Key.ToString()[..8],
                                                    Sets = g.OrderBy(s => s.SetNumber).ToList()
                                                })
                                                .OrderBy(g => g.Name)
                                                .ToList();
                                            var accordionId = $"sessionExercisesAccordion-{session.Id}";

                                            <div class="accordion accordion-flush" id="@accordionId">
                                                @for (var gi = 0; gi < groupedExercises.Count; gi++)
                                                {
                                                    var group = groupedExercises[gi];
                                                    var collapseId = $"exercise-group-{session.Id}-{group.ExerciseId}";
                                                    var headingId = $"heading-{session.Id}-{group.ExerciseId}";
                                                    var isFirst = gi == 0;
                                                    var activeSets = group.Sets.Count(s => s.IsActive);
                                                    <div class="accordion-item">
                                                        <h2 class="accordion-header" id="@headingId">
                                                            <button class="accordion-button @(isFirst ? "" : "collapsed")" type="button"
                                                                    data-coreui-toggle="collapse" data-coreui-target="#@collapseId"
                                                                    aria-expanded="@(isFirst ? "true" : "false")" aria-controls="@collapseId">
                                                                <span class="fw-semibold me-2">@group.Name</span>
                                                                <span class="badge bg-primary-subtle text-primary me-2">@group.Sets.Count set</span>
                                                                @if (activeSets > 0)
                                                                {
                                                                    <span class="badge bg-success-subtle text-success">@activeSets active</span>
                                                                }
                                                            </button>
                                                        </h2>
                                                        <div id="@collapseId" class="accordion-collapse collapse @(isFirst ? "show" : "")"
                                                             aria-labelledby="@headingId">
                                                            <div class="accordion-body p-0">
                                                                <div class="table-responsive">
                                                                    <table class="table table-sm align-middle mb-0">
                                                                        <thead class="table-light">
                                                                            <tr>
                                                                                <th style="width: 80px;">Set</th>
                                                                                <th>Weight</th>
                                                                                <th>Reps</th>
                                                                                <th>Status</th>
                                                                                <th class="text-end" style="width: 140px;"></th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            @foreach (var e in group.Sets)
                                                                            {
                                                                                <tr>
                                                                                    <td class="fw-semibold">@e.SetNumber</td>
                                                                                    <td>@e.Weight</td>
                                                                                    <td>@e.Reps</td>
                                                                                    <td>
                                                                                        @if (e.IsActive)
                                                                                        {
                                                                                            <span class="badge bg-success-subtle text-success">Active</span>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                                                                        }
                                                                                    </td>
                                                                                    <td class="text-end">
                                                                                        @if (!e.IsActive)
                                                                                        {
                                                                                            <form asp-action="ActivateExercise"
                                                                                                  asp-route-id="@session.Id"
                                                                                                  asp-route-exerciseId="@e.Id"
                                                                                                  method="post" class="d-inline">
                                                                                                <input type="hidden" name="returnTo" value="Index" />
                                                                                                <input type="hidden" name="page" value="@Model.PageNumber" />
                                                                                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                                                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Activate">
                                                                                                    <i class="bi bi-check-circle"></i>
                                                                                                </button>
                                                                                            </form>
                                                                                        }
                                                                                        <form asp-action="RemoveExercise"
                                                                                              asp-route-id="@session.Id"
                                                                                              asp-route-exerciseId="@e.Id"
                                                                                              method="post" class="d-inline"
                                                                                              onsubmit="return confirm('Remove this exercise?')">
                                                                                            <input type="hidden" name="returnTo" value="Index" />
                                                                                            <input type="hidden" name="page" value="@Model.PageNumber" />
                                                                                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                                                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                                                <i class="bi bi-x-lg"></i>
                                                                                            </button>
                                                                                        </form>
                                                                                    </td>
                                                                                </tr>
                                                                            }
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }

                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_PaginationPartial", new PaginationViewModel
{
    PageNumber = Model.PageNumber,
    PageSize = Model.PageSize,
    TotalCount = Model.TotalCount,
    TotalPages = Model.TotalPages,
    HasNextPage = Model.HasNextPage,
    HasPreviousPage = Model.HasPreviousPage
})

@section Scripts {
    <script>
        (function () {
            document.querySelectorAll('select.add-set-exercise').forEach(function (select) {
                const targetSelector = select.getAttribute('data-set-input');
                if (!targetSelector) return;
                const setInput = document.querySelector(targetSelector);
                if (!setInput) return;
                select.addEventListener('change', function () {
                    const opt = select.options[select.selectedIndex];
                    const next = opt?.getAttribute('data-next-set');
                    if (next) setInput.value = next;
                });
            });
        })();
    </script>
}
