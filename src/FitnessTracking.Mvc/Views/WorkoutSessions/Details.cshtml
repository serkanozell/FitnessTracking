@model WorkoutSessionDto
@{
    ViewData["Title"] = "Session Details";
    var exercises = Model.Exercises;
    var allExercises = (IReadOnlyList<ExerciseDto>)ViewData["AllExercises"]!;
    var programs = (IReadOnlyList<WorkoutProgramDto>)ViewData["Programs"]!;
    var splits = (IReadOnlyList<WorkoutProgramSplitDto>)(ViewData["Splits"] ?? new List<WorkoutProgramSplitDto>());
    var splitExercises = (Dictionary<Guid, IReadOnlyList<WorkoutProgramExerciseDto>>)(ViewData["SplitExercises"] ?? new Dictionary<Guid, IReadOnlyList<WorkoutProgramExerciseDto>>());
    // O(1) name lookup instead of FirstOrDefault per row.
    var exercisesById = allExercises.ToDictionary(e => e.Id);
    var programName = programs.FirstOrDefault(p => p.Id == Model.WorkoutProgramId)?.Name ?? "Unknown";

    // The session is bound to a specific split; only that split's exercises are valid for adding sets.
    var sessionSplit = splits.FirstOrDefault(s => s.Id == Model.WorkoutProgramSplitId);
    var sessionSplitExercises = (splitExercises.GetValueOrDefault(Model.WorkoutProgramSplitId) ?? [])
        .Where(x => !x.IsDeleted)
        .Select(x => new
        {
            Id = x.ExerciseId,
            Name = exercisesById.TryGetValue(x.ExerciseId, out var ex) ? ex.Name : x.ExerciseName
        })
        .OrderBy(x => x.Name)
        .ToList();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Session — @Model.Date.ToShortDateString()</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to list
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-auto">
                <span class="text-body-secondary small text-uppercase fw-semibold">Program</span>
                <div class="fw-semibold">@programName</div>
            </div>
            <div class="col-auto">
                <span class="text-body-secondary small text-uppercase fw-semibold">Split</span>
                <div class="fw-semibold">
                    @if (sessionSplit is not null)
                    {
                        @($"{sessionSplit.Order}. {sessionSplit.Name}")
                    }
                    else
                    {
                        <span class="text-body-secondary">—</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Exercises grouped accordion -->
<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-list-ol me-2"></i>Exercises
    </div>
    <div class="card-body p-0">
        @if (exercises.Count == 0)
        {
            <div class="text-center text-body-secondary py-5">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>No exercises recorded.
            </div>
        }
        else
        {
            var groupedExercises = exercises
                .GroupBy(x => x.ExerciseId)
                .Select(g => new
                {
                    ExerciseId = g.Key,
                    Name = exercisesById.TryGetValue(g.Key, out var ex) ? ex.Name : g.Key.ToString()[..8],
                    FirstSet = g.Min(s => s.SetNumber),
                    Sets = g.OrderBy(s => s.SetNumber).ToList()
                })
                .OrderBy(g => g.Name)
                .ToList();

            <div class="accordion accordion-flush" id="sessionExercisesAccordion">
                @for (var gi = 0; gi < groupedExercises.Count; gi++)
                {
                    var group = groupedExercises[gi];
                    var collapseId = $"exercise-group-{group.ExerciseId}";
                    var headingId = $"heading-{group.ExerciseId}";
                    var isFirst = gi == 0;
                    var activeSets = group.Sets.Count(s => s.IsActive);
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="@headingId">
                            <button class="accordion-button @(isFirst ? "" : "collapsed")" type="button"
                                    data-coreui-toggle="collapse" data-coreui-target="#@collapseId"
                                    aria-expanded="@(isFirst ? "true" : "false")" aria-controls="@collapseId">
                                <span class="fw-semibold me-2">@group.Name</span>
                                <span class="badge bg-primary-subtle text-primary me-2">@group.Sets.Count set</span>
                                @if (activeSets > 0)
                                {
                                    <span class="badge bg-success-subtle text-success">@activeSets active</span>
                                }
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse @(isFirst ? "show" : "")"
                             aria-labelledby="@headingId">
                            <div class="accordion-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 80px;">Set</th>
                                                <th>Weight</th>
                                                <th>Reps</th>
                                                <th>Status</th>
                                                <th class="text-end" style="width: 140px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var e in group.Sets)
                                            {
                                                var editId = $"edit-set-{e.Id}";
                                                <tr>
                                                    <td class="fw-semibold">@e.SetNumber</td>
                                                    <td>@e.Weight</td>
                                                    <td>@e.Reps</td>
                                                    <td>
                                                        @if (e.IsActive)
                                                        {
                                                            <span class="badge bg-success-subtle text-success">Active</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                                        }
                                                    </td>
                                                    <td class="text-end">
                                                        <button type="button" class="btn btn-sm btn-outline-primary" title="Edit"
                                                                data-coreui-toggle="collapse" data-coreui-target="#@editId">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                        @if (!e.IsActive)
                                                        {
                                                            <form asp-action="ActivateExercise"
                                                                  asp-route-id="@Model.Id"
                                                                  asp-route-exerciseId="@e.Id"
                                                                  method="post" class="d-inline">
                                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Activate">
                                                                    <i class="bi bi-check-circle"></i>
                                                                </button>
                                                            </form>
                                                        }
                                                        <form asp-action="RemoveExercise"
                                                              asp-route-id="@Model.Id"
                                                              asp-route-exerciseId="@e.Id"
                                                              method="post" class="d-inline"
                                                              onsubmit="return confirm('Remove this exercise?')">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                <i class="bi bi-x-lg"></i>
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <tr class="collapse" id="@editId">
                                                    <td colspan="5" class="bg-body-tertiary">
                                                        <form asp-action="UpdateExercise"
                                                              asp-route-id="@Model.Id"
                                                              asp-route-workoutExerciseId="@e.Id"
                                                              method="post">
                                                            <div class="row g-2 align-items-end">
                                                                <div class="col-md-3">
                                                                    <label class="form-label">Exercise</label>
                                                                    <select name="exerciseId" class="form-select" required>
                                                                        @foreach (var ex in allExercises)
                                                                        {
                                                                            if (ex.Id == e.ExerciseId)
                                                                            {
                                                                                <option value="@ex.Id" selected>@ex.Name</option>
                                                                            }
                                                                            else
                                                                            {
                                                                                <option value="@ex.Id">@ex.Name</option>
                                                                            }
                                                                        }
                                                                    </select>
                                                                </div>
                                                                <div class="col-md-2">
                                                                    <label class="form-label">Set #</label>
                                                                    <input name="setNumber" type="number" class="form-control"
                                                                           value="@e.SetNumber" min="1" />
                                                                </div>
                                                                <div class="col-md-2">
                                                                    <label class="form-label">Weight</label>
                                                                    <input name="weight" type="number" step="0.5" class="form-control"
                                                                           value="@e.Weight" />
                                                                </div>
                                                                <div class="col-md-2">
                                                                    <label class="form-label">Reps</label>
                                                                    <input name="reps" type="number" class="form-control"
                                                                           value="@e.Reps" min="1" />
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <button type="submit" class="btn btn-primary w-100">
                                                                        <i class="bi bi-check-lg me-1"></i>Save
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </form>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Add Exercise -->
<div class="card">
    <div class="card-header">
        <i class="bi bi-plus-circle me-2"></i>Add Set
    </div>
    <div class="card-body">
        @if (sessionSplit is null)
        {
            <div class="alert alert-warning mb-0">
                <i class="bi bi-exclamation-triangle me-1"></i>
                The split bound to this session no longer exists.
            </div>
        }
        else if (sessionSplitExercises.Count == 0)
        {
            <div class="alert alert-warning mb-0">
                <i class="bi bi-exclamation-triangle me-1"></i>
                The bound split has no exercises. Add exercises to the split first.
            </div>
        }
        else
        {
            var nextSetByExercise = exercises
                .GroupBy(x => x.ExerciseId)
                .ToDictionary(g => g.Key, g => g.Count() + 1);

            <form asp-action="AddExercise" asp-route-id="@Model.Id" method="post" id="addSetForm">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Exercise</label>
                        <select name="exerciseId" id="addSetExerciseSelect" class="form-select" required>
                            <option value="">-- select --</option>
                            @foreach (var ex in sessionSplitExercises)
                            {
                                var nextSet = nextSetByExercise.GetValueOrDefault(ex.Id, 1);
                                <option value="@ex.Id" data-next-set="@nextSet">@ex.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Set #</label>
                        <input name="setNumber" id="addSetNumber" type="number" class="form-control" value="1" min="1" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Weight</label>
                        <input name="weight" type="number" step="0.5" class="form-control" value="0" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Reps</label>
                        <input name="reps" type="number" class="form-control" value="10" min="1" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-plus-lg me-1"></i>Add Set
                        </button>
                    </div>
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const select = document.getElementById('addSetExerciseSelect');
            const setInput = document.getElementById('addSetNumber');
            if (!select || !setInput) return;
            select.addEventListener('change', function () {
                const opt = select.options[select.selectedIndex];
                const next = opt?.getAttribute('data-next-set');
                if (next) setInput.value = next;
            });
        })();
    </script>
}

