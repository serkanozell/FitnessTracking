@{
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var actionName = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FitnessTracking</title>
    <link href="https://cdn.jsdelivr.net/npm/@@coreui/coreui@5.2.0/dist/css/coreui.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="sidebar sidebar-dark sidebar-fixed" id="sidebar">
            <div class="sidebar-header border-bottom">
                <div class="sidebar-brand d-flex align-items-center gap-2">
                    <i class="bi bi-heart-pulse-fill fs-4"></i>
                    <span class="sidebar-brand-full fw-semibold">FitnessTracking</span>
                    <span class="sidebar-brand-narrow fw-bold">FT</span>
                </div>
            </div>
            <ul class="sidebar-nav">
                <li class="nav-item">
                    <a class="nav-link @(controllerName == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <i class="nav-icon bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-title">Training</li>
                <li class="nav-item">
                    <a class="nav-link @(controllerName == "Exercises" ? "active" : "")" asp-controller="Exercises" asp-action="Index">
                        <i class="nav-icon bi bi-activity"></i> Exercises
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(controllerName == "WorkoutPrograms" ? "active" : "")" asp-controller="WorkoutPrograms" asp-action="Index">
                        <i class="nav-icon bi bi-list-check"></i> Programs
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(controllerName == "WorkoutSessions" ? "active" : "")" asp-controller="WorkoutSessions" asp-action="Index">
                        <i class="nav-icon bi bi-play-circle"></i> Sessions
                    </a>
                </li>
                <li class="nav-title">Tracking</li>
                <li class="nav-item">
                    <a class="nav-link @(controllerName == "BodyMetrics" ? "active" : "")" asp-controller="BodyMetrics" asp-action="Index">
                        <i class="nav-icon bi bi-clipboard2-pulse"></i> Body Metrics
                    </a>
                </li>
            </ul>
            <div class="sidebar-footer border-top d-none d-md-flex">
                <button class="sidebar-toggler" type="button" data-coreui-toggle="unfoldable"></button>
            </div>
        </div>
    }

    <div class="wrapper d-flex flex-column min-vh-100 @(User.Identity?.IsAuthenticated == true ? "" : "ps-0")">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <header class="header header-sticky p-0 mb-4">
                <div class="container-fluid px-4">
                    <button class="header-toggler d-lg-none" type="button"
                            data-coreui-toggle="sidebar" data-coreui-target="#sidebar">
                        <i class="bi bi-list fs-4"></i>
                    </button>
                    <ul class="header-nav ms-auto">
                        <li class="nav-item d-flex align-items-center">
                            <span class="text-body-secondary me-3">
                                <i class="bi bi-person-circle me-1"></i>@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
                <div class="container-fluid px-4">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb my-0">
                            <li class="breadcrumb-item">
                                <a asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            @if (controllerName != "Home")
                            {
                                <li class="breadcrumb-item">
                                    <a asp-controller="@controllerName" asp-action="Index">@controllerName</a>
                                </li>
                            }
                            @if (!string.IsNullOrEmpty(ViewData["Title"]?.ToString()))
                            {
                                <li class="breadcrumb-item active">@ViewData["Title"]</li>
                            }
                        </ol>
                    </nav>
                </div>
            </header>
        }

        <div class="body flex-grow-1">
            <div class="container-lg px-4">
                @if (TempData["Success"] is string success)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@success
                        <button type="button" class="btn-close" data-coreui-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] is string error)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>@error
                        <button type="button" class="btn-close" data-coreui-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>

        <footer class="footer px-4">
            <div><span class="fw-semibold">FitnessTracking</span> &copy; @DateTime.Now.Year</div>
            <div class="ms-auto">Powered by <a href="https://coreui.io" target="_blank" rel="noopener">CoreUI</a></div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@@coreui/coreui@5.2.0/dist/js/coreui.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
