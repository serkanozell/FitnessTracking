@model PaginationViewModel
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = "Index";

    // Build a fresh route-data dict per link so we can override page/pageSize per anchor.
    Dictionary<string, string> RouteFor(int page, int pageSize)
    {
        var dict = new Dictionary<string, string>(Model.ExtraRouteValues, StringComparer.OrdinalIgnoreCase)
        {
            ["page"] = page.ToString(),
            ["pageSize"] = pageSize.ToString()
        };
        return dict;
    }

    // For the per-page <select> we need the URL of page 1 with the new pageSize, while
    // preserving any other route values (filters such as programId, expand, etc.).
    string PageSizeUrl(int newPageSize)
    {
        var values = new Dictionary<string, string>(Model.ExtraRouteValues, StringComparer.OrdinalIgnoreCase)
        {
            ["page"] = "1",
            ["pageSize"] = newPageSize.ToString()
        };
        return Url.Action(action, controller, values) ?? "?page=1&pageSize=" + newPageSize;
    }
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mt-3">
    <div class="text-body-secondary small">
        @if (Model.TotalCount == 0)
        {
            <span>No results</span>
        }
        else
        {
            <span>Showing <strong>@Model.StartItem</strong> to <strong>@Model.EndItem</strong> of <strong>@Model.TotalCount</strong> results</span>
        }
    </div>

    <div class="d-flex align-items-center gap-3">
        <div class="d-flex align-items-center gap-2">
            <label class="form-label mb-0 small text-body-secondary text-nowrap">Per page</label>
            <select class="form-select form-select-sm" style="width: auto;"
                    data-pagesize-options='@System.Text.Json.JsonSerializer.Serialize(PaginationViewModel.PageSizeOptions.ToDictionary(s => s, PageSizeUrl))'
                    onchange="window.location.href = JSON.parse(this.dataset.pagesizeOptions)[this.value];">
                @foreach (var size in PaginationViewModel.PageSizeOptions)
                {
                    <option value="@size" selected="@(size == Model.PageSize)">@size</option>
                }
            </select>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-controller="@controller" asp-action="@action"
                           asp-all-route-data="RouteFor(Math.Max(Model.PageNumber - 1, 1), Model.PageSize)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    @{
                        int start, end;
                        if (Model.TotalPages <= 7)
                        {
                            start = 1;
                            end = Model.TotalPages;
                        }
                        else if (Model.PageNumber <= 3)
                        {
                            start = 1;
                            end = 5;
                        }
                        else if (Model.PageNumber >= Model.TotalPages - 2)
                        {
                            start = Model.TotalPages - 4;
                            end = Model.TotalPages;
                        }
                        else
                        {
                            start = Model.PageNumber - 2;
                            end = Model.PageNumber + 2;
                        }
                    }

                    @if (start > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-controller="@controller" asp-action="@action"
                               asp-all-route-data="RouteFor(1, Model.PageSize)">1</a>
                        </li>
                        @if (start > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }

                    @for (var i = start; i <= end; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link"
                               asp-controller="@controller" asp-action="@action"
                               asp-all-route-data="RouteFor(i, Model.PageSize)">@i</a>
                        </li>
                    }

                    @if (end < Model.TotalPages)
                    {
                        @if (end < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link"
                               asp-controller="@controller" asp-action="@action"
                               asp-all-route-data="RouteFor(Model.TotalPages, Model.PageSize)">@Model.TotalPages</a>
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-controller="@controller" asp-action="@action"
                           asp-all-route-data="RouteFor(Math.Min(Model.PageNumber + 1, Model.TotalPages), Model.PageSize)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
