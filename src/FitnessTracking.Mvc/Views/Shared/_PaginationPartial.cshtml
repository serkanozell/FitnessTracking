@model PaginationViewModel
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = "Index";
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mt-3">
    <div class="text-body-secondary small">
        @if (Model.TotalCount == 0)
        {
            <span>No results</span>
        }
        else
        {
            <span>Showing <strong>@Model.StartItem</strong> to <strong>@Model.EndItem</strong> of <strong>@Model.TotalCount</strong> results</span>
        }
    </div>

    <div class="d-flex align-items-center gap-3">
        <div class="d-flex align-items-center gap-2">
            <label class="form-label mb-0 small text-body-secondary text-nowrap">Per page</label>
            <select class="form-select form-select-sm" style="width: auto;"
                    onchange="window.location.href='?page=1&pageSize='+this.value">
                @foreach (var size in PaginationViewModel.PageSizeOptions)
                {
                    <option value="@size" selected="@(size == Model.PageSize)">@size</option>
                }
            </select>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-controller="@controller" asp-action="@action"
                           asp-route-page="@(Model.PageNumber - 1)" asp-route-pageSize="@Model.PageSize">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    @{
                        int start, end;
                        if (Model.TotalPages <= 7)
                        {
                            start = 1;
                            end = Model.TotalPages;
                        }
                        else if (Model.PageNumber <= 3)
                        {
                            start = 1;
                            end = 5;
                        }
                        else if (Model.PageNumber >= Model.TotalPages - 2)
                        {
                            start = Model.TotalPages - 4;
                            end = Model.TotalPages;
                        }
                        else
                        {
                            start = Model.PageNumber - 2;
                            end = Model.PageNumber + 2;
                        }
                    }

                    @if (start > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-controller="@controller" asp-action="@action"
                               asp-route-page="1" asp-route-pageSize="@Model.PageSize">1</a>
                        </li>
                        @if (start > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }

                    @for (var i = start; i <= end; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link"
                               asp-controller="@controller" asp-action="@action"
                               asp-route-page="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                        </li>
                    }

                    @if (end < Model.TotalPages)
                    {
                        @if (end < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link"
                               asp-controller="@controller" asp-action="@action"
                               asp-route-page="@Model.TotalPages" asp-route-pageSize="@Model.PageSize">@Model.TotalPages</a>
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-controller="@controller" asp-action="@action"
                           asp-route-page="@(Model.PageNumber + 1)" asp-route-pageSize="@Model.PageSize">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
