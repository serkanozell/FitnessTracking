@model MealPlanDto
@{
    ViewData["Title"] = Model.Name;
    var foods = (IReadOnlyList<FoodDto>)ViewData["Foods"]!;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">@Model.Name</h4>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to list
        </a>
    </div>
</div>

<!-- Summary -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center border-warning">
            <div class="card-body py-3">
                <div class="text-body-secondary small text-uppercase fw-semibold">Calories</div>
                <div class="fs-4 fw-bold text-warning">@Model.TotalCalories.ToString("F0")</div>
                <div class="text-body-secondary small">kcal</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-danger">
            <div class="card-body py-3">
                <div class="text-body-secondary small text-uppercase fw-semibold">Protein</div>
                <div class="fs-4 fw-bold text-danger">@Model.TotalProtein.ToString("F1")</div>
                <div class="text-body-secondary small">gram</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-primary">
            <div class="card-body py-3">
                <div class="text-body-secondary small text-uppercase fw-semibold">Carbs</div>
                <div class="fs-4 fw-bold text-primary">@Model.TotalCarbohydrates.ToString("F1")</div>
                <div class="text-body-secondary small">gram</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-success">
            <div class="card-body py-3">
                <div class="text-body-secondary small text-uppercase fw-semibold">Fat</div>
                <div class="fs-4 fw-bold text-success">@Model.TotalFat.ToString("F1")</div>
                <div class="text-body-secondary small">gram</div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-auto">
        <span class="text-body-secondary small text-uppercase fw-semibold">Date</span>
        <div class="fw-semibold">@Model.Date.ToShortDateString()</div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Note))
    {
        <div class="col">
            <span class="text-body-secondary small text-uppercase fw-semibold">Note</span>
            <div>@Model.Note</div>
        </div>
    }
</div>

<!-- Add Meal -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-plus-circle me-2"></i>Add Meal</div>
    <div class="card-body">
        <form asp-action="AddMeal" asp-route-id="@Model.Id" method="post">
            <div class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input name="name" class="form-control" placeholder="e.g. Breakfast, Lunch, Dinner" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Order</label>
                    <input name="order" type="number" class="form-control" value="@(Model.Meals.Count + 1)" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-plus-lg me-1"></i>Add Meal
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Meals -->
@if (Model.Meals.Count == 0)
{
    <div class="card">
        <div class="card-body text-center text-body-secondary py-5">
            <i class="bi bi-cup-straw fs-1 d-block mb-2"></i>No meals yet. Add your first meal above.
        </div>
    </div>
}

@foreach (var meal in Model.Meals)
{
    <div class="card mb-4">
        <div class="card-header d-flex align-items-center justify-content-between">
            <div>
                <i class="bi bi-cup-hot me-2"></i>
                <strong>@meal.Name</strong>
                <span class="text-body-secondary ms-2 small">
                    @meal.MealCalories.ToString("F0") kcal ·
                    P @meal.MealProtein.ToString("F1")g ·
                    C @meal.MealCarbohydrates.ToString("F1")g ·
                    F @meal.MealFat.ToString("F1")g
                </span>
            </div>
            <form asp-action="RemoveMeal" asp-route-id="@Model.Id" asp-route-mealId="@meal.Id" method="post"
                  onsubmit="return confirm('Remove this meal and all its items?')">
                <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove meal">
                    <i class="bi bi-trash"></i>
                </button>
            </form>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Food</th>
                        <th class="text-end">Qty</th>
                        <th>Unit</th>
                        <th class="text-end">Cal</th>
                        <th class="text-end">P</th>
                        <th class="text-end">C</th>
                        <th class="text-end">F</th>
                        <th class="text-end" style="width:140px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in meal.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.FoodName</td>
                            <td class="text-end">@item.Quantity</td>
                            <td>@item.ServingUnit</td>
                            <td class="text-end">@item.Calories.ToString("F0")</td>
                            <td class="text-end">@item.Protein.ToString("F1")</td>
                            <td class="text-end">@item.Carbohydrates.ToString("F1")</td>
                            <td class="text-end">@item.Fat.ToString("F1")</td>
                            <td class="text-end">
                                <form asp-action="UpdateMealItemQuantity"
                                      asp-route-id="@Model.Id" asp-route-mealId="@meal.Id" asp-route-mealItemId="@item.Id"
                                      method="post" class="d-inline">
                                    <div class="input-group input-group-sm" style="width:90px; display:inline-flex !important;">
                                        <input name="quantity" type="number" step="0.1" value="@item.Quantity"
                                               class="form-control form-control-sm" style="width:55px;" />
                                        <button type="submit" class="btn btn-outline-primary btn-sm" title="Update qty">
                                            <i class="bi bi-arrow-repeat"></i>
                                        </button>
                                    </div>
                                </form>
                                <form asp-action="RemoveMealItem"
                                      asp-route-id="@Model.Id" asp-route-mealId="@meal.Id" asp-route-mealItemId="@item.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Remove this item?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (meal.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center text-body-secondary py-3">No food items yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Add food item to this meal -->
        <div class="card-footer bg-light">
            <form asp-action="AddMealItem" asp-route-id="@Model.Id" asp-route-mealId="@meal.Id" method="post">
                <div class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label small">Food</label>
                        <select name="foodId" class="form-select form-select-sm" required>
                            <option value="">Select a food…</option>
                            @foreach (var f in foods.Where(x => x.IsActive))
                            {
                                <option value="@f.Id">@f.Name (@f.Calories kcal / @f.DefaultServingSize @f.ServingUnit)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Quantity</label>
                        <input name="quantity" type="number" step="0.1" value="1" class="form-control form-control-sm" required />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-sm btn-primary w-100">
                            <i class="bi bi-plus-lg me-1"></i>Add Food
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}
