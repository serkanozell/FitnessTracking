@model PagedResult<MealPlanDto>
@{
    ViewData["Title"] = "Meal Plans";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Meal Plans</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Plan
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40px;"></th>
                        <th>Name</th>
                        <th>Date</th>
                        <th class="text-end">Calories</th>
                        <th class="text-end">Protein</th>
                        <th class="text-end">Carbs</th>
                        <th class="text-end">Fat</th>
                        <th class="text-center">Meals</th>
                        <th>Status</th>
                        <th class="text-end" style="width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="10" class="text-center text-body-secondary py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>No meal plans found.
                            </td>
                        </tr>
                    }
                    @foreach (var p in Model.Items)
                    {
                        var collapseId = $"meals-{p.Id}";
                        <tr>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-link p-0 meal-plan-toggle"
                                        data-coreui-toggle="collapse" data-coreui-target="#@collapseId"
                                        aria-expanded="false" aria-controls="@collapseId" title="Show meals">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@p.Id" class="fw-semibold text-decoration-none">@p.Name</a>
                            </td>
                            <td>@p.Date.ToShortDateString()</td>
                            <td class="text-end fw-semibold">@p.TotalCalories.ToString("F0")</td>
                            <td class="text-end">@p.TotalProtein.ToString("F1")g</td>
                            <td class="text-end">@p.TotalCarbohydrates.ToString("F1")g</td>
                            <td class="text-end">@p.TotalFat.ToString("F1")g</td>
                            <td class="text-center">
                                <span class="badge bg-info-subtle text-info">@p.Meals.Count</span>
                            </td>
                            <td>
                                @if (p.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (!p.IsActive)
                                {
                                    <form asp-action="Activate" asp-route-id="@p.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Activate">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>
                                }
                                <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this meal plan?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <tr class="collapse-row">
                            <td colspan="10" class="p-0 border-0">
                                <div id="@collapseId" class="collapse">
                                    <div class="p-3 bg-light border-top">
                                        @if (p.Meals.Count == 0)
                                        {
                                            <div class="text-center text-body-secondary py-3">
                                                <i class="bi bi-cup-straw me-1"></i>No meals in this plan yet.
                                                <a asp-action="Details" asp-route-id="@p.Id" class="ms-2">Add meals</a>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="accordion" id="accordion-@p.Id">
                                                @foreach (var meal in p.Meals)
                                                {
                                                    var headingId = $"heading-{p.Id}-{meal.Id}";
                                                    var bodyId = $"body-{p.Id}-{meal.Id}";
                                                    <div class="accordion-item">
                                                        <h2 class="accordion-header" id="@headingId">
                                                            <button class="accordion-button collapsed" type="button"
                                                                    data-coreui-toggle="collapse" data-coreui-target="#@bodyId"
                                                                    aria-expanded="false" aria-controls="@bodyId">
                                                                <div class="d-flex flex-wrap align-items-center gap-3 w-100 me-3">
                                                                    <span class="fw-semibold">
                                                                        <i class="bi bi-cup-hot me-2"></i>@meal.Name
                                                                    </span>
                                                                    <span class="text-body-secondary small">
                                                                        @meal.MealCalories.ToString("F0") kcal ·
                                                                        P @meal.MealProtein.ToString("F1")g ·
                                                                        C @meal.MealCarbohydrates.ToString("F1")g ·
                                                                        F @meal.MealFat.ToString("F1")g
                                                                    </span>
                                                                    <span class="badge bg-secondary-subtle text-secondary ms-auto">
                                                                        @meal.Items.Count item(s)
                                                                    </span>
                                                                </div>
                                                            </button>
                                                        </h2>
                                                        <div id="@bodyId" class="accordion-collapse collapse"
                                                             aria-labelledby="@headingId">
                                                            <div class="accordion-body p-0">
                                                                @if (meal.Items.Count == 0)
                                                                {
                                                                    <div class="text-center text-body-secondary py-3">No food items.</div>
                                                                }
                                                                else
                                                                {
                                                                    <table class="table table-sm align-middle mb-0">
                                                                        <thead class="table-light">
                                                                            <tr>
                                                                                <th>Food</th>
                                                                                <th class="text-end">Qty</th>
                                                                                <th>Unit</th>
                                                                                <th class="text-end">Cal</th>
                                                                                <th class="text-end">P</th>
                                                                                <th class="text-end">C</th>
                                                                                <th class="text-end">F</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            @foreach (var item in meal.Items)
                                                                            {
                                                                                <tr>
                                                                                    <td class="fw-semibold">@item.FoodName</td>
                                                                                    <td class="text-end">@item.Quantity</td>
                                                                                    <td>@item.ServingUnit</td>
                                                                                    <td class="text-end">@item.Calories.ToString("F0")</td>
                                                                                    <td class="text-end">@item.Protein.ToString("F1")</td>
                                                                                    <td class="text-end">@item.Carbohydrates.ToString("F1")</td>
                                                                                    <td class="text-end">@item.Fat.ToString("F1")</td>
                                                                                </tr>
                                                                            }
                                                                        </tbody>
                                                                    </table>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                            <div class="text-end mt-3">
                                                <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-info">
                                                    <i class="bi bi-eye me-1"></i>Open Details
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_PaginationPartial", new PaginationViewModel
{
    PageNumber = Model.PageNumber,
    PageSize = Model.PageSize,
    TotalCount = Model.TotalCount,
    TotalPages = Model.TotalPages,
    HasNextPage = Model.HasNextPage,
    HasPreviousPage = Model.HasPreviousPage
})

<style>
    .meal-plan-toggle i { transition: transform 0.2s ease-in-out; }
    .meal-plan-toggle[aria-expanded="true"] i { transform: rotate(90deg); }
</style>
