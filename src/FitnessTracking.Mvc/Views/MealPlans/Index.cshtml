@model PagedResult<MealPlanDto>
@{
    ViewData["Title"] = "Meal Plans";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Meal Plans</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Plan
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Date</th>
                        <th class="text-end">Calories</th>
                        <th class="text-end">Protein</th>
                        <th class="text-end">Carbs</th>
                        <th class="text-end">Fat</th>
                        <th>Status</th>
                        <th class="text-end" style="width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center text-body-secondary py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>No meal plans found.
                            </td>
                        </tr>
                    }
                    @foreach (var p in Model.Items)
                    {
                        <tr>
                            <td>
                                <a asp-action="Details" asp-route-id="@p.Id" class="fw-semibold text-decoration-none">@p.Name</a>
                            </td>
                            <td>@p.Date.ToShortDateString()</td>
                            <td class="text-end fw-semibold">@p.TotalCalories.ToString("F0")</td>
                            <td class="text-end">@p.TotalProtein.ToString("F1")g</td>
                            <td class="text-end">@p.TotalCarbohydrates.ToString("F1")g</td>
                            <td class="text-end">@p.TotalFat.ToString("F1")g</td>
                            <td>
                                @if (p.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (!p.IsActive)
                                {
                                    <form asp-action="Activate" asp-route-id="@p.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Activate">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>
                                }
                                <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this meal plan?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_PaginationPartial", new PaginationViewModel
{
    PageNumber = Model.PageNumber,
    PageSize = Model.PageSize,
    TotalCount = Model.TotalCount,
    TotalPages = Model.TotalPages,
    HasNextPage = Model.HasNextPage,
    HasPreviousPage = Model.HasPreviousPage
})
