@model DailyNutritionLogEditModel
@{
    ViewData["Title"] = "New Daily Log";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">New Daily Log</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to list
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="Date" class="form-label"></label>
                    <input asp-for="Date" class="form-control" type="date" />
                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="DailyCalorieGoal" class="form-label">Calorie Goal</label>
                    <div class="input-group">
                        <input asp-for="DailyCalorieGoal" class="form-control" type="number" step="1" placeholder="e.g. 2000" />
                        <span class="input-group-text">kcal</span>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Note" class="form-label"></label>
                <textarea asp-for="Note" class="form-control" rows="2"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Create
                </button>
                <a asp-action="Index" class="btn btn-ghost-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
