@model DailyNutritionLogDto
@{
    ViewData["Title"] = $"Daily Log — {Model.Date:yyyy-MM-dd}";
    var foods = (IReadOnlyList<FoodDto>)ViewData["Foods"]!;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Daily Log — @Model.Date.ToString("yyyy-MM-dd")</h4>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to list
        </a>
    </div>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center border-warning">
            <div class="card-body py-3">
                <div class="text-body-secondary small text-uppercase fw-semibold">Calories</div>
                <div class="fs-4 fw-bold text-warning">@Model.TotalCalories.ToString("F0")</div>
                <div class="text-body-secondary small">kcal</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-danger">
            <div class="card-body py-3">
                <div class="text-body-secondary small text-uppercase fw-semibold">Protein</div>
                <div class="fs-4 fw-bold text-danger">@Model.TotalProtein.ToString("F1")</div>
                <div class="text-body-secondary small">gram</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-primary">
            <div class="card-body py-3">
                <div class="text-body-secondary small text-uppercase fw-semibold">Carbs</div>
                <div class="fs-4 fw-bold text-primary">@Model.TotalCarbohydrates.ToString("F1")</div>
                <div class="text-body-secondary small">gram</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-success">
            <div class="card-body py-3">
                <div class="text-body-secondary small text-uppercase fw-semibold">Fat</div>
                <div class="fs-4 fw-bold text-success">@Model.TotalFat.ToString("F1")</div>
                <div class="text-body-secondary small">gram</div>
            </div>
        </div>
    </div>
</div>

<!-- Goal & Remaining -->
@if (Model.DailyCalorieGoal.HasValue)
{
    var remaining = Model.RemainingCalories!.Value;
    var progressPct = Model.DailyCalorieGoal.Value > 0
        ? Math.Min(100, (int)(Model.TotalCalories / Model.DailyCalorieGoal.Value * 100))
        : 0;
    var barColor = remaining >= 0 ? "bg-success" : "bg-danger";

    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
                <span class="fw-semibold">Daily Goal: @Model.DailyCalorieGoal.Value.ToString("F0") kcal</span>
                <span class="fw-semibold @(remaining >= 0 ? "text-success" : "text-danger")">
                    @(remaining >= 0 ? $"{remaining:F0} kcal remaining" : $"{Math.Abs(remaining):F0} kcal over")
                </span>
            </div>
            <div class="progress" style="height: 10px;">
                <div class="progress-bar @barColor" role="progressbar" style="width: @progressPct%"></div>
            </div>
        </div>
    </div>
}

<div class="row mb-4">
    @if (!string.IsNullOrWhiteSpace(Model.Note))
    {
        <div class="col">
            <span class="text-body-secondary small text-uppercase fw-semibold">Note</span>
            <div>@Model.Note</div>
        </div>
    }
</div>

<!-- Add Entry -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-plus-circle me-2"></i>Add Food Entry</div>
    <div class="card-body">
        <form asp-action="AddEntry" asp-route-id="@Model.Id" method="post">
            <div class="row g-2 align-items-end">
                <div class="col-md-5">
                    <label class="form-label">Food</label>
                    <select name="foodId" class="form-select" required>
                        <option value="">Select a food...</option>
                        @foreach (var f in foods)
                        {
                            <option value="@f.Id">@f.Name (@f.Calories kcal / @f.DefaultServingSize @f.ServingUnit)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Quantity</label>
                    <input name="quantity" type="number" step="0.1" min="0.1" class="form-control" value="1" required />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-plus-lg me-1"></i>Add Entry
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Entries Table -->
<div class="card mb-4">
    <div class="card-header"><i class="bi bi-journal-text me-2"></i>Food Entries</div>
    <div class="card-body p-0">
        <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Food</th>
                    <th class="text-end">Qty</th>
                    <th>Unit</th>
                    <th class="text-end">Cal</th>
                    <th class="text-end">P</th>
                    <th class="text-end">C</th>
                    <th class="text-end">F</th>
                    <th class="text-end" style="width:140px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.Entries)
                {
                    <tr>
                        <td class="fw-semibold">@entry.FoodName</td>
                        <td class="text-end">@entry.Quantity</td>
                        <td>@entry.ServingUnit</td>
                        <td class="text-end">@entry.Calories.ToString("F0")</td>
                        <td class="text-end">@entry.Protein.ToString("F1")</td>
                        <td class="text-end">@entry.Carbohydrates.ToString("F1")</td>
                        <td class="text-end">@entry.Fat.ToString("F1")</td>
                        <td class="text-end">
                            <form asp-action="UpdateEntryQuantity"
                                  asp-route-id="@Model.Id" asp-route-entryId="@entry.Id"
                                  method="post" class="d-inline">
                                <div class="input-group input-group-sm" style="width:90px; display:inline-flex !important;">
                                    <input name="quantity" type="number" step="0.1" value="@entry.Quantity"
                                           class="form-control form-control-sm" style="width:55px;" />
                                    <button type="submit" class="btn btn-outline-primary btn-sm" title="Update qty">
                                        <i class="bi bi-arrow-repeat"></i>
                                    </button>
                                </div>
                            </form>
                            <form asp-action="RemoveEntry"
                                  asp-route-id="@Model.Id" asp-route-entryId="@entry.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Remove this entry?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (Model.Entries.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center text-body-secondary py-5">
                            <i class="bi bi-egg fs-1 d-block mb-2"></i>No food entries yet. Add your first entry above.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
