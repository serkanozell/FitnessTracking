@model PagedResult<DailyNutritionLogDto>
@{
    ViewData["Title"] = "Calorie Tracker";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Calorie Tracker</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Log
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40px;"></th>
                        <th>Date</th>
                        <th class="text-end">Goal</th>
                        <th class="text-end">Calories</th>
                        <th class="text-end">Remaining</th>
                        <th class="text-end">Protein</th>
                        <th class="text-end">Carbs</th>
                        <th class="text-end">Fat</th>
                        <th class="text-center">Entries</th>
                        <th class="text-end" style="width: 160px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="10" class="text-center text-body-secondary py-5">
                                <i class="bi bi-journal-text fs-1 d-block mb-2"></i>No daily logs found. Start tracking your calories!
                            </td>
                        </tr>
                    }
                    @foreach (var log in Model.Items)
                    {
                        var collapseId = $"entries-{log.Id}";
                        <tr>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-link p-0 meal-plan-toggle"
                                        data-coreui-toggle="collapse" data-coreui-target="#@collapseId"
                                        aria-expanded="false" aria-controls="@collapseId" title="Show entries">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@log.Id" class="fw-semibold text-decoration-none">
                                    @log.Date.ToString("yyyy-MM-dd")
                                </a>
                            </td>
                            <td class="text-end">
                                @if (log.DailyCalorieGoal.HasValue)
                                {
                                    @log.DailyCalorieGoal.Value.ToString("F0")<span class="text-body-secondary small"> kcal</span>
                                }
                                else
                                {
                                    <span class="text-body-secondary">—</span>
                                }
                            </td>
                            <td class="text-end fw-semibold">@log.TotalCalories.ToString("F0")</td>
                            <td class="text-end">
                                @if (log.RemainingCalories.HasValue)
                                {
                                    var remaining = log.RemainingCalories.Value;
                                    var cls = remaining >= 0 ? "text-success" : "text-danger";
                                    <span class="@cls fw-semibold">@remaining.ToString("F0")</span>
                                }
                                else
                                {
                                    <span class="text-body-secondary">—</span>
                                }
                            </td>
                            <td class="text-end">@log.TotalProtein.ToString("F1")g</td>
                            <td class="text-end">@log.TotalCarbohydrates.ToString("F1")g</td>
                            <td class="text-end">@log.TotalFat.ToString("F1")g</td>
                            <td class="text-center">
                                <span class="badge bg-info-subtle text-info">@log.Entries.Count</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@log.Id" class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@log.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@log.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this daily log?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <tr class="collapse-row">
                            <td colspan="10" class="p-0 border-0">
                                <div id="@collapseId" class="collapse">
                                    <div class="p-3 bg-light border-top">
                                        @if (log.Entries.Count == 0)
                                        {
                                            <p class="text-body-secondary mb-0">No entries yet.</p>
                                        }
                                        else
                                        {
                                            <table class="table table-sm table-borderless mb-0">
                                                <thead>
                                                    <tr class="text-body-secondary small">
                                                        <th>Food</th>
                                                        <th class="text-end">Qty</th>
                                                        <th>Unit</th>
                                                        <th class="text-end">Cal</th>
                                                        <th class="text-end">P</th>
                                                        <th class="text-end">C</th>
                                                        <th class="text-end">F</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var entry in log.Entries)
                                                    {
                                                        <tr>
                                                            <td>@entry.FoodName</td>
                                                            <td class="text-end">@entry.Quantity</td>
                                                            <td>@entry.ServingUnit</td>
                                                            <td class="text-end">@entry.Calories.ToString("F0")</td>
                                                            <td class="text-end">@entry.Protein.ToString("F1")</td>
                                                            <td class="text-end">@entry.Carbohydrates.ToString("F1")</td>
                                                            <td class="text-end">@entry.Fat.ToString("F1")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<partial name="_PaginationPartial" model="new PaginationViewModel
{
    PageNumber = Model.PageNumber,
    PageSize = Model.PageSize,
    TotalCount = Model.TotalCount,
    TotalPages = Model.TotalPages,
    HasNextPage = Model.HasNextPage,
    HasPreviousPage = Model.HasPreviousPage
}" />
