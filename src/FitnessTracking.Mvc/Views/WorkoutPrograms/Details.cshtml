@model WorkoutProgramDto
@{
    ViewData["Title"] = Model.Name;
    var splits = (IReadOnlyList<WorkoutProgramSplitDto>)ViewData["Splits"]!;
    var splitExercises = (Dictionary<Guid, IReadOnlyList<WorkoutProgramExerciseDto>>)ViewData["SplitExercises"]!;
    var allExercises = (IReadOnlyList<ExerciseDto>)ViewData["AllExercises"]!;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">@Model.Name</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to list
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-auto">
                <span class="text-body-secondary small text-uppercase fw-semibold">Start Date</span>
                <div class="fw-semibold">@Model.StartDate.ToShortDateString()</div>
            </div>
            <div class="col-auto">
                <span class="text-body-secondary small text-uppercase fw-semibold">End Date</span>
                <div class="fw-semibold">@Model.EndDate.ToShortDateString()</div>
            </div>
        </div>
    </div>
</div>

<!-- Add Split -->
<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-plus-circle me-2"></i>Add Split
    </div>
    <div class="card-body">
        <form asp-action="AddSplit" asp-route-id="@Model.Id" method="post">
            <div class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input name="name" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Order</label>
                    <input name="order" type="number" class="form-control" value="@(splits.Count + 1)" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-plus-lg me-1"></i>Add Split
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Splits -->
@if (splits.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-collection text-body-secondary" style="font-size: 2.5rem;"></i>
            <p class="text-body-secondary mt-2 mb-0">No splits created yet.</p>
        </div>
    </div>
}
else
{
    <div class="accordion" id="splitsAccordion">
        @foreach (var split in splits.OrderBy(s => s.Order))
        {
            var exercises = splitExercises.GetValueOrDefault(split.Id) ?? [];
            var collapseId = $"collapse-{split.Id}";
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-coreui-toggle="collapse"
                            data-coreui-target="#@collapseId">
                        <span class="badge bg-primary me-2">@split.Order</span> @split.Name
                        <span class="badge bg-secondary-subtle text-secondary ms-2">@exercises.Count exercises</span>
                    </button>
                </h2>
                <div id="@collapseId" class="accordion-collapse collapse" data-coreui-parent="#splitsAccordion">
                    <div class="accordion-body">
                        <!-- Split actions -->
                        <div class="d-flex gap-2 mb-3">
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    data-coreui-toggle="collapse" data-coreui-target="#edit-split-@split.Id">
                                <i class="bi bi-pencil me-1"></i>Edit Split
                            </button>
                            <form asp-action="DeleteSplit" asp-route-id="@Model.Id" asp-route-splitId="@split.Id"
                                  method="post" onsubmit="return confirm('Delete this split?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash me-1"></i>Delete Split
                                </button>
                            </form>
                        </div>

                        <!-- Edit split form (collapsible) -->
                        <div class="collapse mb-3" id="edit-split-@split.Id">
                            <div class="card card-body bg-body-tertiary">
                                <form asp-action="UpdateSplit" asp-route-id="@Model.Id" asp-route-splitId="@split.Id"
                                      method="post">
                                    <div class="row g-2 align-items-end">
                                        <div class="col-md-6">
                                            <label class="form-label">Name</label>
                                            <input name="name" class="form-control" value="@split.Name" required />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Order</label>
                                            <input name="order" type="number" class="form-control" value="@split.Order" min="1" />
                                        </div>
                                        <div class="col-md-3">
                                            <button type="submit" class="btn btn-primary w-100">
                                                <i class="bi bi-check-lg me-1"></i>Save
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- Add exercise to split -->
                        <form asp-action="AddExerciseToSplit" asp-route-id="@Model.Id" asp-route-splitId="@split.Id"
                              method="post" class="mb-3">
                            <div class="row g-2 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label">Exercise</label>
                                    <select name="exerciseId" class="form-select" required>
                                        <option value="">-- select --</option>
                                        @foreach (var ex in allExercises)
                                        {
                                            <option value="@ex.Id">@ex.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Sets</label>
                                    <input name="sets" type="number" class="form-control" value="3" min="1" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Min Reps</label>
                                    <input name="minimumReps" type="number" class="form-control" value="8" min="1" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Max Reps</label>
                                    <input name="maximumReps" type="number" class="form-control" value="12" min="1" />
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="bi bi-plus-lg me-1"></i>Add
                                    </button>
                                </div>
                            </div>
                        </form>

                        <!-- Exercises table -->
                        @if (exercises.Count == 0)
                        {
                            <p class="text-body-secondary mb-0">No exercises in this split.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Exercise</th>
                                            <th>Sets</th>
                                            <th>Rep Range</th>
                                            <th class="text-end" style="width: 100px;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var e in exercises)
                                        {
                                            <tr>
                                                <td class="fw-semibold">@e.ExerciseName</td>
                                                <td>@e.Sets</td>
                                                <td>@e.MinimumReps — @e.MaximumReps</td>
                                                <td class="text-end">
                                                    <form asp-action="RemoveExerciseFromSplit"
                                                          asp-route-id="@Model.Id"
                                                          asp-route-splitId="@split.Id"
                                                          asp-route-exerciseId="@e.WorkoutProgramExerciseId"
                                                          method="post" class="d-inline"
                                                          onsubmit="return confirm('Remove this exercise?')">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
