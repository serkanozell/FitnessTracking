@model ExerciseEditModel
@{
    ViewData["Title"] = "New Exercise";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">New Exercise</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to list
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="PrimaryMuscleGroup" class="form-label"></label>
                    <select asp-for="PrimaryMuscleGroup" class="form-select"
                            asp-items="@(new SelectList(ExerciseEditModel.MuscleGroups))">
                        <option value="">-- select --</option>
                    </select>
                    <span asp-validation-for="PrimaryMuscleGroup" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SecondaryMuscleGroup" class="form-label"></label>
                    <select asp-for="SecondaryMuscleGroup" class="form-select"
                            asp-items="@(new SelectList(ExerciseEditModel.MuscleGroups))">
                        <option value="">-- none --</option>
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Create
                </button>
                <a asp-action="Index" class="btn btn-ghost-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
