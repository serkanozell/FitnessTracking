@model PagedResult<ExerciseDto>
@{
    ViewData["Title"] = "Exercises";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Exercises</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Exercise
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th></th>
                        <th>Name</th>
                        <th>Primary Muscle</th>
                        <th>Secondary Muscle</th>
                        <th>Status</th>
                        <th class="text-end" style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-body-secondary py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>No exercises found.
                            </td>
                        </tr>
                    }
                    @foreach (var e in Model.Items)
                    {
                        <tr>
                            <td style="width: 48px;">
                                @if (!string.IsNullOrEmpty(e.ImageUrl))
                                {
                                    <img src="@e.ImageUrl" alt="@e.Name" class="rounded" style="width:40px;height:40px;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="rounded bg-body-secondary d-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                                        <i class="bi bi-image text-body-tertiary"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-semibold">
                                @e.Name
                                @if (!string.IsNullOrEmpty(e.VideoUrl))
                                {
                                    <a href="@e.VideoUrl" target="_blank" class="ms-1 text-danger" title="Watch video">
                                        <i class="bi bi-play-circle-fill"></i>
                                    </a>
                                }
                            </td>
                            <td>@e.PrimaryMuscleGroup</td>
                            <td>@(e.SecondaryMuscleGroup ?? "—")</td>
                            <td>
                                @if (e.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (!e.IsActive && e.IsDeleted)
                                {
                                    <form asp-action="Activate" asp-route-id="@e.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Activate">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>
                                }
                                @if (e.IsActive && !e.IsDeleted)
                                {
                                    <form asp-action="Delete" asp-route-id="@e.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this exercise?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_PaginationPartial", new PaginationViewModel
{
    PageNumber = Model.PageNumber,
    PageSize = Model.PageSize,
    TotalCount = Model.TotalCount,
    TotalPages = Model.TotalPages,
    HasNextPage = Model.HasNextPage,
    HasPreviousPage = Model.HasPreviousPage
})
