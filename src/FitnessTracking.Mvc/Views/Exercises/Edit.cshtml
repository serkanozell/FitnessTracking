@model ExerciseEditModel
@{
    ViewData["Title"] = "Edit Exercise";
    var exerciseId = (Guid)ViewData["ExerciseId"]!;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Edit Exercise</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to list
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@exerciseId" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="PrimaryMuscleGroup" class="form-label"></label>
                    <select asp-for="PrimaryMuscleGroup" class="form-select"
                            asp-items="@(new SelectList(ExerciseEditModel.MuscleGroups))">
                        <option value="">-- select --</option>
                    </select>
                    <span asp-validation-for="PrimaryMuscleGroup" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SecondaryMuscleGroup" class="form-label"></label>
                    <select asp-for="SecondaryMuscleGroup" class="form-select"
                            asp-items="@(new SelectList(ExerciseEditModel.MuscleGroups))">
                        <option value="">-- none --</option>
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <h6 class="fw-semibold text-body-secondary mb-3">
                <i class="bi bi-image me-1"></i>Media
            </h6>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Exercise Image</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-2 p-2 border rounded d-inline-block position-relative">
                            <img src="@Model.ImageUrl" alt="Current image" class="rounded" style="max-height:120px;" />
                        </div>
                        <div class="form-check mb-2">
                            <input asp-for="RemoveImage" class="form-check-input" type="checkbox" />
                            <label asp-for="RemoveImage" class="form-check-label text-danger small">Remove current image</label>
                        </div>
                    }
                    <input asp-for="ImageFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,.gif" />
                    <div class="form-text">JPG, PNG, WebP or GIF. Max 5 MB. Leave empty to keep current.</div>
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="VideoUrl" class="form-label">Video URL</label>
                    <input asp-for="VideoUrl" class="form-control" type="url" placeholder="https://..." />
                    <span asp-validation-for="VideoUrl" class="text-danger"></span>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save
                </button>
                <a asp-action="Index" class="btn btn-ghost-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
