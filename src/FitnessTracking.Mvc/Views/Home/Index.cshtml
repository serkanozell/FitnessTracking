@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Dashboard</h4>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-body-secondary text-uppercase small fw-semibold mb-2">Total Workouts</div>
                        <div class="fs-4 fw-semibold">—</div>
                    </div>
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-activity"></i>
                    </div>
                </div>
                <div class="small text-body-secondary mt-2">
                    <i class="bi bi-arrow-up text-success"></i> Since last month
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-body-secondary text-uppercase small fw-semibold mb-2">Streak</div>
                        <div class="fs-4 fw-semibold">—</div>
                    </div>
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-fire"></i>
                    </div>
                </div>
                <div class="small text-body-secondary mt-2">
                    <i class="bi bi-calendar-check text-warning"></i> Consecutive days
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-body-secondary text-uppercase small fw-semibold mb-2">Weight</div>
                        <div class="fs-4 fw-semibold">—</div>
                    </div>
                    <div class="stat-icon bg-info bg-opacity-10 text-info">
                        <i class="bi bi-speedometer"></i>
                    </div>
                </div>
                <div class="small text-body-secondary mt-2">
                    <i class="bi bi-dash text-body-secondary"></i> No change
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-body-secondary text-uppercase small fw-semibold mb-2">Active Program</div>
                        <div class="fs-4 fw-semibold">—</div>
                    </div>
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-list-check"></i>
                    </div>
                </div>
                <div class="small text-body-secondary mt-2">
                    <i class="bi bi-clock text-success"></i> Currently running
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body text-center py-5">
        <i class="bi bi-bar-chart-line text-body-secondary" style="font-size: 3rem;"></i>
        <p class="text-body-secondary mt-3 mb-0">
            Dashboard data will be available after the dashboard API is connected.
        </p>
    </div>
</div>
