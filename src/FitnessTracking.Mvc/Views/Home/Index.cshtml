@{
    ViewData["Title"] = "Dashboard";
}

<h4 class="mb-4">Dashboard</h4>

<div class="row g-3">
    <div class="col-sm-6 col-md-3">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-activity text-primary" style="font-size: 2rem;"></i>
                <div>
                    <small class="text-muted">Total Workouts</small>
                    <h5 class="mb-0">—</h5>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-fire text-warning" style="font-size: 2rem;"></i>
                <div>
                    <small class="text-muted">Streak</small>
                    <h5 class="mb-0">—</h5>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-speedometer text-info" style="font-size: 2rem;"></i>
                <div>
                    <small class="text-muted">Weight</small>
                    <h5 class="mb-0">—</h5>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-list-check text-success" style="font-size: 2rem;"></i>
                <div>
                    <small class="text-muted">Active Program</small>
                    <h5 class="mb-0">—</h5>
                </div>
            </div>
        </div>
    </div>
</div>

<p class="text-muted mt-4">
    <small>Dashboard data will be available after the dashboard API is connected.</small>
</p>
