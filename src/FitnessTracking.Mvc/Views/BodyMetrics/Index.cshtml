@model PagedResult<BodyMetricDto>
@{
    ViewData["Title"] = "Body Metrics";

    static string Fmt(decimal? value, string suffix) =>
        value.HasValue ? $"{value.Value:F1}{suffix}" : "—";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Body Metrics</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Entry
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Weight</th>
                        <th>Height</th>
                        <th>Body Fat</th>
                        <th>Muscle Mass</th>
                        <th>Chest</th>
                        <th>Waist</th>
                        <th>Hip</th>
                        <th>Arm</th>
                        <th>Thigh</th>
                        <th>Neck</th>
                        <th>Note</th>
                        <th>Status</th>
                        <th class="text-end" style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="14" class="text-center text-body-secondary py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>No body metrics found.
                            </td>
                        </tr>
                    }
                    @foreach (var m in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@m.Date.ToShortDateString()</td>
                            <td>@Fmt(m.Weight, " kg")</td>
                            <td>@Fmt(m.Height, " cm")</td>
                            <td>@(m.BodyFatPercentage.HasValue ? $"{m.BodyFatPercentage:F1}%" : "—")</td>
                            <td>@Fmt(m.MuscleMass, " kg")</td>
                            <td>@Fmt(m.ChestCircumference, " cm")</td>
                            <td>@Fmt(m.WaistCircumference, " cm")</td>
                            <td>@Fmt(m.HipCircumference, " cm")</td>
                            <td>@Fmt(m.ArmCircumference, " cm")</td>
                            <td>@Fmt(m.ThighCircumference, " cm")</td>
                            <td>@Fmt(m.NeckCircumference, " cm")</td>
                            <td class="text-truncate" style="max-width: 200px;" title="@m.Note">
                                @(string.IsNullOrWhiteSpace(m.Note) ? "—" : m.Note)
                            </td>
                            <td>
                                @if (m.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@m.Id" class="btn btn-sm btn-outline-secondary" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (!m.IsActive)
                                {
                                    <form asp-action="Activate" asp-route-id="@m.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Activate">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>
                                }
                                <form asp-action="Delete" asp-route-id="@m.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this entry?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_PaginationPartial", new PaginationViewModel
{
    PageNumber = Model.PageNumber,
    PageSize = Model.PageSize,
    TotalCount = Model.TotalCount,
    TotalPages = Model.TotalPages,
    HasNextPage = Model.HasNextPage,
    HasPreviousPage = Model.HasPreviousPage
})
