@model BodyMetricEditModel
@{
    ViewData["Title"] = "Add Body Metric";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="page-title">Add Body Metric</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to list
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="Date" class="form-label"></label>
                <input asp-for="Date" class="form-control" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <h6 class="fw-semibold text-body-secondary mb-3">
                <i class="bi bi-rulers me-1"></i>Measurements
            </h6>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Weight" class="form-label">Weight (kg)</label>
                    <input asp-for="Weight" class="form-control" type="number" step="0.1" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Height" class="form-label">Height (cm)</label>
                    <input asp-for="Height" class="form-control" type="number" step="0.1" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="BodyFatPercentage" class="form-label">Body Fat (%)</label>
                    <input asp-for="BodyFatPercentage" class="form-control" type="number" step="0.1" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="MuscleMass" class="form-label">Muscle Mass (kg)</label>
                    <input asp-for="MuscleMass" class="form-control" type="number" step="0.1" />
                </div>
            </div>

            <h6 class="fw-semibold text-body-secondary mb-3">
                <i class="bi bi-arrows-angle-expand me-1"></i>Circumferences (cm)
            </h6>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="ChestCircumference" class="form-label">Chest</label>
                    <input asp-for="ChestCircumference" class="form-control" type="number" step="0.1" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="WaistCircumference" class="form-label">Waist</label>
                    <input asp-for="WaistCircumference" class="form-control" type="number" step="0.1" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="HipCircumference" class="form-label">Hip</label>
                    <input asp-for="HipCircumference" class="form-control" type="number" step="0.1" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="ArmCircumference" class="form-label">Arm</label>
                    <input asp-for="ArmCircumference" class="form-control" type="number" step="0.1" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="ThighCircumference" class="form-label">Thigh</label>
                    <input asp-for="ThighCircumference" class="form-control" type="number" step="0.1" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="NeckCircumference" class="form-label">Neck</label>
                    <input asp-for="NeckCircumference" class="form-control" type="number" step="0.1" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="ShoulderCircumference" class="form-label">Shoulder</label>
                    <input asp-for="ShoulderCircumference" class="form-control" type="number" step="0.1" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Note" class="form-label">Note</label>
                <textarea asp-for="Note" class="form-control" rows="2"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save
                </button>
                <a asp-action="Index" class="btn btn-ghost-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
